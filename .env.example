# =============================================================================
# papermantra-infra — production environment template
# Copy to .env on the VPS:  cp .env.example .env && nano .env
# =============================================================================

COMPOSE_PROJECT_NAME=papermantra

# ── Container registry (GHCR matches existing app-repo CI workflows) ──────────
REGISTRY=ghcr.io
REGISTRY_OWNER=sagaranawade

# Pin tags per service (updated by deploy workflow or manually on rollback)
IMAGE_PAPERMANTRA=${REGISTRY}/${REGISTRY_OWNER}/papermantra-web:latest
IMAGE_ROBOFUME=${REGISTRY}/${REGISTRY_OWNER}/robofume:latest
IMAGE_SERVICES=${REGISTRY}/${REGISTRY_OWNER}/papermantraservices:latest
IMAGE_PDF=${REGISTRY}/${REGISTRY_OWNER}/pdf-generator:latest

# ── Domains (used by Certbot and Nginx) ───────────────────────────────────────
DOMAIN_PAPERMANTRA=papermantra.com
DOMAIN_PAPERMANTRA_WWW=www.papermantra.com
DOMAIN_NEELMIND=neelmind.com
DOMAIN_NEELMIND_WWW=www.neelmind.com
DOMAIN_API=api.papermantra.com
DOMAIN_PDF=pdf.papermantra.com

# Certbot contact email for expiry notices
CERTBOT_EMAIL=ops@papermantra.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGODB_DATABASE=papermantra
MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${MONGODB_DATABASE}?authSource=admin

# PDF service uses its own DB name on the same Mongo instance
PDF_MONGODB_DATABASE=pdfgenerator

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL_ENABLED=false

# ── Papermantra Services (Spring Boot API) ────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG
JWT_EXPIRATION_MS=604800000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GEN_CLIENT_ID=
GOOGLE_GEN_CLIENT_SECRET=
GOOGLE_GEN_REDIRECT_URI=https://api.papermantra.com/papermantra/api/v1/googledrive/oauth2callback
GOOGLE_GEN_JS_ORIGINS=https://papermantra.com,https://www.papermantra.com

# ── PDF Generator (Spring Boot) ──────────────────────────────────────────────
PDF_MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${PDF_MONGODB_DATABASE}?authSource=admin
JWT_ISSUER=papermantra
AUTH_BASE_URL=https://api.papermantra.com/papermantra
AUTH_USERNAME=
AUTH_PASSWORD=
QP_BASE_URL=https://api.papermantra.com/papermantra
PDF_BASE_URL=https://pdf.papermantra.com/pdfgenerator
CORS_ALLOWED_ORIGINS=https://papermantra.com,https://www.papermantra.com
CORS_ALLOWED_PATTERNS=https://*.papermantra.com

# ── Grafana (optional monitoring profile) ─────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
