# Google OAuth client id/secret: baked into papermantraservices image (application.properties).
# Only prod URLs are overridden here:
GOOGLE_GEN_REDIRECT_URI=https://api.papermantra.com/papermantra/api/v1/googledrive/oauth2callback
GOOGLE_GEN_JS_ORIGINS=https://papermantra.com,https://www.papermantra.com

PDF_MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${PDF_MONGODB_DATABASE}?authSource=admin
JWT_ISSUER=papermantra

AUTH_BASE_URL=https://api.papermantra.com/papermantra
