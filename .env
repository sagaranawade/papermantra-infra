JWT_EXPIRATION_MS=2592000000

# Google OAuth client id/secret: baked into papermantraservices image (application.properties).
# Register these EXACT URIs in Google Cloud Console â†’ OAuth 2.0 Client â†’ Authorized redirect URIs:
#   https://api.papermantra.com/papermantra/login/oauth2/code/google
#   http://localhost:9091/papermantra/login/oauth2/code/google
GOOGLE_OAUTH_REDIRECT_URI=https://api.papermantra.com/papermantra/login/oauth2/code/google
OAUTH_FRONTEND_BASE_URL=https://www.neelmind.com
OAUTH_ALLOWED_FRONTEND_URLS=https://www.neelmind.com,https://neelmind.com,https://papermantra.com,https://www.papermantra.com
# Password setup/reset links in emails (PaperMantra portal â€” not NeelMind marketing)
PORTAL_BASE_URL=https://www.papermantra.com
GOOGLE_GEN_REDIRECT_URI=https://api.papermantra.com/papermantra/api/v1/googledrive/oauth2callback
GOOGLE_GEN_JS_ORIGINS=https://papermantra.com,https://www.papermantra.com,https://neelmind.com,https://www.neelmind.com

PDF_MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${PDF_MONGODB_DATABASE}?authSource=admin&retryWrites=true&w=majority
JWT_ISSUER=papermantra

# PDF â†’ API inter-service URLs (host only â€” paths in pdfgenerator include /papermantra/api/v1/...)
AUTH_BASE_URL=http://api:9091
AUTH_USERNAME=admin@papermantra.com
AUTH_PASSWORD=neelsa@papermantra.com
QP_BASE_URL=http://api:9091
PDF_BASE_URL=https://pdf.papermantra.com/pdfgenerator
BRANDING_BASE_URL=http://api:9091

CORS_ALLOWED_ORIGINS=https://papermantra.com,https://www.papermantra.com,https://neelmind.com,https://www.neelmind.com
CORS_ALLOWED_PATTERNS=https://papermantra.com,https://www.papermantra.com,https://*.papermantra.com,https://neelmind.com,https://www.neelmind.com,https://*.neelmind.com

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeit

