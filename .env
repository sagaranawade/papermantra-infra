# =============================================================================
# Production environment â€” committed on main (single VPS, no separate .env setup).
# Edit here and push to main; VPS gets values via git pull + deploy.
# =============================================================================

COMPOSE_PROJECT_NAME=papermantra

REGISTRY=ghcr.io
REGISTRY_OWNER=sagaranawade

# Image tags â€” each service can use a different version.
# Unified release (e.g. v1.0.6): set all four to the same tag, or run infra deploy
#   workflow with image_tag=v1.0.6 and pin_all=true.
# Single-service release: tag one repo; its CI updates only its IMAGE_* line in .env.
IMAGE_PAPERMANTRA=${REGISTRY}/${REGISTRY_OWNER}/papermantra:v1.0.49
IMAGE_ROBOFUME=${REGISTRY}/${REGISTRY_OWNER}/robofume:v1.0.29
IMAGE_SERVICES=${REGISTRY}/${REGISTRY_OWNER}/papermantraservices:v1.0.45
IMAGE_PDF=${REGISTRY}/${REGISTRY_OWNER}/pdf-generator:v1.0.18

DOMAIN_PAPERMANTRA=papermantra.com
DOMAIN_PAPERMANTRA_WWW=www.papermantra.com
DOMAIN_NEELMIND=neelmind.com
DOMAIN_NEELMIND_WWW=www.neelmind.com
DOMAIN_API=api.papermantra.com
DOMAIN_PDF=pdf.papermantra.com

CERTBOT_EMAIL=123sagar.anawade@gmail.com

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=LhlAyB0kvlEs1tKF1jrwp0sEoCoo62Qs582zNae1PUkCaUzvTStWyDy7M3EPFtkT
MONGODB_DATABASE=papermantra
MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${MONGODB_DATABASE}?authSource=admin&retryWrites=true&w=majority

PDF_MONGODB_DATABASE=pdfgenerator

REDIS_PASSWORD=k3feNcAW4FuekjnWYM5dRJ1q0EkWqCF2QsuM+dEJSwjLqcCkSdxnFlbwtreA3YDf
