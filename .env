# =============================================================================
# Production environment — committed on main (single VPS, no separate .env setup).
# Edit here and push to main; VPS gets values via git pull + deploy.
# =============================================================================

COMPOSE_PROJECT_NAME=papermantra

REGISTRY=ghcr.io
REGISTRY_OWNER=sagaranawade

# Image tags — each service can use a different version.
# Unified release (e.g. v1.0.6): set all four to the same tag, or run infra deploy
#   workflow with image_tag=v1.0.6 and pin_all=true.
# Single-service release: tag one repo; its CI updates only its IMAGE_* line in .env.
IMAGE_PAPERMANTRA=${REGISTRY}/${REGISTRY_OWNER}/papermantra-web:v1.0.11
IMAGE_ROBOFUME=${REGISTRY}/${REGISTRY_OWNER}/robofume:v1.0.11
IMAGE_SERVICES=${REGISTRY}/${REGISTRY_OWNER}/papermantraservices:v1.0.11
IMAGE_PDF=${REGISTRY}/${REGISTRY_OWNER}/pdf-generator:v1.0.11

DOMAIN_PAPERMANTRA=papermantra.com
DOMAIN_PAPERMANTRA_WWW=www.papermantra.com
DOMAIN_NEELMIND=neelmind.com
DOMAIN_NEELMIND_WWW=www.neelmind.com
DOMAIN_API=api.papermantra.com
DOMAIN_PDF=pdf.papermantra.com

CERTBOT_EMAIL=123sagar.anawade@gmail.com

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=LhlAyB0kvlEs1tKF1jrwp0sEoCoo62Qs582zNae1PUkCaUzvTStWyDy7M3EPFtkT
MONGODB_DATABASE=papermantra
MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${MONGODB_DATABASE}?authSource=admin&retryWrites=true&w=majority

PDF_MONGODB_DATABASE=pdfgenerator

REDIS_PASSWORD=k3feNcAW4FuekjnWYM5dRJ1q0EkWqCF2QsuM+dEJSwjLqcCkSdxnFlbwtreA3YDf
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL_ENABLED=false

JWT_SECRET=changeit
JWT_EXPIRATION_MS=2592000000

# Google OAuth client id/secret: baked into papermantraservices image (application.properties).
# Register these EXACT URIs in Google Cloud Console → OAuth 2.0 Client → Authorized redirect URIs:
#   https://api.papermantra.com/papermantra/login/oauth2/code/google
#   http://localhost:9091/papermantra/login/oauth2/code/google
GOOGLE_OAUTH_REDIRECT_URI=https://api.papermantra.com/papermantra/login/oauth2/code/google
OAUTH_FRONTEND_BASE_URL=https://www.neelmind.com
OAUTH_ALLOWED_FRONTEND_URLS=https://www.neelmind.com,https://neelmind.com,https://papermantra.com,https://www.papermantra.com
GOOGLE_GEN_REDIRECT_URI=https://api.papermantra.com/papermantra/api/v1/googledrive/oauth2callback
GOOGLE_GEN_JS_ORIGINS=https://papermantra.com,https://www.papermantra.com,https://neelmind.com,https://www.neelmind.com

PDF_MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${PDF_MONGODB_DATABASE}?authSource=admin&retryWrites=true&w=majority
JWT_ISSUER=papermantra

# PDF → API inter-service URLs (host only — paths in pdfgenerator include /papermantra/api/v1/...)
AUTH_BASE_URL=http://api:9091
AUTH_USERNAME=admin@papermantra.com
AUTH_PASSWORD=neelsa@papermantra.com
QP_BASE_URL=http://api:9091
PDF_BASE_URL=https://pdf.papermantra.com/pdfgenerator
BRANDING_BASE_URL=http://api:9091

CORS_ALLOWED_ORIGINS=https://papermantra.com,https://www.papermantra.com,https://neelmind.com,https://www.neelmind.com
CORS_ALLOWED_PATTERNS=https://papermantra.com,https://www.papermantra.com,https://*.papermantra.com,https://neelmind.com,https://www.neelmind.com,https://*.neelmind.com

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeit
