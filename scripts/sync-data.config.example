# Copy to sync-data.config and edit paths for your machine.
# Used by sync-data-to-prod, image-sync, image-replace, and branding-sync scripts.

PAPERMANTRA_SERVICES_ROOT=D:/PaperMantra Projects/Git Hub New Repos/papermantraservices
PDFGENERATOR_ROOT=D:/PaperMantra Projects/Git Hub New Repos/pdfgenerator

VPS_HOST=187.127.189.114
VPS_USER=deploy
VPS_PATH=/opt/papermantra-infra
SSH_KEY=C:/Users/Sagar/.ssh/papermantra_deploy_ci

# Cloudflare Access hostname for permanent Mongo (see docs/MONGO-ACCESS.md)
# MONGO_CF_HOSTNAME=mongo.papermantra.com

# Local MongoDB (native install or Docker publishing 27017)
LOCAL_MONGO_HOST=host.docker.internal
LOCAL_MONGO_PORT=27017

# Database names on prod (must match papermantra-infra/.env)
PAPERMANTRA_DB=papermantra
PDFGENERATOR_DB=pdfgenerator
